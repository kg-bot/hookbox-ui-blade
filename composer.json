{
    "name": "kg-bot/hookbox-ui-blade",
    "description": "Blade adapter for the Hookbox inbox and message details UI.",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "kg-bot/hookbox-ui-core": "^1.0",
        "illuminate/config": "^12.0 || ^13.0",
        "illuminate/contracts": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0",
        "illuminate/session": "^12.0 || ^13.0",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/view": "^12.0 || ^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^2.11 || ^3.0",
        "laravel/framework": "^12.0 || ^13.0",
        "laravel/pint": "^1.17",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.12.17 || ^2.1.44",
        "phpunit/phpunit": "^10.5 || ^11.5"
    },
    "autoload": {
        "psr-4": {
            "Hookbox\\UiBlade\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Hookbox\\UiBlade\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "format:test": "vendor/bin/pint --test",
        "test": "vendor/bin/phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Hookbox\\UiBlade\\HookboxUiBladeServiceProvider"
            ]
        }
    }
}
